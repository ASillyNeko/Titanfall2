"SpriteCard"
{
	"$basetexture" "particle\leaf\floret.vtf"
	$vertexcolor 1
	$vertexalpha 1


//	$alphatest 1
//	$AlphaTestReference 0.3

	$translucent 1
	$depthblend 1
	$depthblendscale 512

	$nocull 1

	$maxsize 0.1
	$minsize 0.001

	$vertexFogAmount 1

    $disableTSAA 0
	$tsaaFullyResponsive 1
    $tsaaMotionAlphaThreshold 0
    $tsaaMotionAlphaRamp 1000
}